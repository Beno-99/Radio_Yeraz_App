{
  "expo": {
    "name": "Radio Yeraz",
    "slug": "radioyeraz",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "radioyeraz",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/images/icon.png",
      "supportsTablet": true,
      "googleServicesFile": "./google-services.json",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "icon": "./assets/images/icon.png",
      "adaptiveIcon": {
        "backgroundColor": "#070B14",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "package": "com.radioyeraz.radioyeraz",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-radioLogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#070b14",
          "dark": {
            "backgroundColor": "#070b14"
          }
        }
      ],
      "expo-audio",
      "expo-video",
      "expo-asset",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "./plugins/withNotificationIcon",
      "./plugins/withAndroidVideoFullscreen",
      "./plugins/withAndroidApiUserAgent",
      [
        "expo-audio",
        {
          "microphonePermission": false
        }
      ],
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "none",
          "cameraPermission": "none"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "buildToolsVersion": "34.0.0",
            "kotlinVersion": "2.0.21"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bcec4d7f-bc03-472a-8b42-6204b01e06e5"
      }
    }
  }
}
